---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (
  await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  })
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Journal — Charlotte Thornet"
  description="Actualités, notes et coulisses d'écriture de Charlotte Thornet."
  canonical="/journal"
>
  <h1>Journal</h1>

  <section class="post-list">
    {
      posts.map((post) => (
        <article class:list={["post-preview", { "post-preview-with-image": post.data.image }]}>
          <div>
            <p class="eyebrow">{post.data.category}</p>

            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("fr-FR")}
            </time>

            <h2>
              <a href={`/journal/${post.id}`}>{post.data.title}</a>
            </h2>

            <p>{post.data.description}</p>
          </div>

          {post.data.image && (
            <a
              class="post-preview-image"
              href={`/journal/${post.id}`}
              aria-label={`Lire l’article ${post.data.title}`}
            >
              <img
                src={post.data.image}
                alt={post.data.imageAlt ?? `Illustration de l’article ${post.data.title}`}
              />
            </a>
          )}
        </article>
      ))
    }
  </section>
</BaseLayout>
